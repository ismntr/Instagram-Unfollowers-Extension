{
  "manifest_version": 3,
  "name": "Instagram Unfollower Extension",
  "version": "1.0.0",
  "description": "Bulk unfollow Instagram users from a CSV file with smart rate-limit protection.",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Unfollower Extension"
  }
}
